@baseUrl = http://localhost:3000
@api = {{baseUrl}}/api
@id = 1

### LIST
GET {{api}}/staff

### CREATE
POST {{api}}/staff
Content-Type: application/json

{
  "business_id": 1,
  "branch_id": 1,
  "full_name": "Ahmet Usta",
  "phone": "05000000002",
  "is_active": 1
}

### GET
GET {{api}}/staff/{{id}}

### UPDATE
PUT {{api}}/staff/{{id}}
Content-Type: application/json

{
  "full_name": "Ahmet Usta (Güncel)"
}

### DELETE
DELETE {{api}}/staff/{{id}}
